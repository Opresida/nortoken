{
  "name": "nortoken-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist dist-server",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@privy-io/react-auth": "^3.29.1",
    "@tanstack/react-query": "^5.90.21",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.545.0",
    "motion": "^12.23.24",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "^3.8.1",
    "viem": "^2.52.2",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "esbuild": "0.27.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^7.3.0"
  }
}

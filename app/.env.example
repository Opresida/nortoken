# Copie para .env e preencha. NUNCA commitar o .env real.

# ─── Carteira Web3 (Privy) ───
# App ID do Privy (privy.io) — é público (vai no bundle do cliente).
VITE_PRIVY_APP_ID=""
# Modo da carteira: 'mock' (sandbox) | 'testnet' (Privy + deploy real). Ausente = mock.
VITE_WALLET_MODE="mock"

# ─── Co-pilot Gemini (opcional, server-side) ───
# Se vazia, o endpoint /api/copilot roda em modo simulação determinística.
# Obtenha em https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# ─── App URL ───
# Em dev, deixe vazio (Express usa http://localhost:3000).
APP_URL=""

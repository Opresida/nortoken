# Copie para .env e preencha. NUNCA commitar o .env real.

# RPC de Base Sepolia (Alchemy/dRPC — Humberto já usa no ZEUS EVM)
BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/SUA_CHAVE

# Chave privada da carteira deployer (de TESTE — nunca uma com fundos reais)
DEPLOYER_PK=0x...

# Endereço do keeper que ajusta o range do lock (testnet: EOA controlada; prod: multisig Safe)
KEEPER_ADDR=0x...

# Tesouro Nortoken que recebe o fee de protocolo de 0,2% (captado no hook)
PROTOCOL_TREASURY=0x...

# API key do BaseScan para verificar contratos
BASESCAN_API_KEY=...
